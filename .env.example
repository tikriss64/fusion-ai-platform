# ─── Plantilla de variables de entorno ───────────────────────────────
# Copia este archivo a .env y rellena los valores. NUNCA subas .env a git.

# Supabase (fuente única de datos)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Conexión SQL directa para el Inbox (shim D1). Usar el TRANSACTION POOLER
# (puerto 6543) + ?sslmode=require, no la conexión directa 5432.
SUPABASE_DB_URL=
# Tenant activo del servidor (id de public.tenants). Single-tenant funciona sin él.
FUSION_TENANT_ID=
# Si activas facturación en Gemini (no entrena con tus datos), ponlo a true.
GEMINI_BILLING_ENABLED=false

# ─── Proveedores de IA (todos con tier gratuito) ─────────────────────
# El router usa el que esté disponible; el fallback es automático.

# Groq — tier gratis 14.400 req/día (Llama 3.3 8B/70B). Datos anónimos.
GROQ_API_KEY=

# OpenRouter — modelos gratis (DeepSeek V3/R1, Qwen3). Overflow del Nivel 1.
OPENROUTER_API_KEY=

# Gemini — tier gratis 1.500 req/día (3.5 Flash) para casos complejos.
# Para datos con PII, activar facturación (deja de entrenar con tus datos).
GEMINI_API_KEY=

# Claude (Anthropic API) — PREMIUM OPCIONAL, pago por tokens. Si la pones, el
# router usa Claude para el nivel 2 (tareas complejas/sensibles); NO entrena con
# tus datos → apto para PII. Si la dejas vacía, todo sigue 100% gratis.
ANTHROPIC_API_KEY=

# ─── Bandeja IA · Gmail ──────────────────────────────────────────────
# Credenciales OAuth de Google para que los correos entren en la Bandeja.
# Cómo conseguirlas: ver GUIA-CONECTAR-GMAIL.md (paso a paso, ~15 min).
# URI de redirección autorizada en Google: http://localhost:8080/api/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Login único de la Bandeja. En local déjalo en false (un solo usuario en tu PC).
# Al publicar online, ponlo a true: exige la sesión de Supabase del CRM para
# acceder a las rutas /api/* de la Bandeja.
INBOX_REQUIRE_AUTH=false

# Router IA (ahorro de tokens) en el "preguntar a la Bandeja". Déjalo en false
# hasta probarlo juntos: en true, las preguntas pasan por la cascada con caché
# (regla→caché exacta→caché semántica→modelo gratis) y enmascarado de PII.
# Si el router falla o degrada, cae automáticamente al método actual (riesgo cero).
INBOX_USE_ROUTER=false
